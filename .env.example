#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = development
# Valid values: production | development | testing

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'http://localhost:8080/'
# If you have a custom domain, change accordingly.

# Force HTTPS? Uncomment to redirect all HTTP to HTTPS.
# app.forceGlobalSecureRequests = true

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database.default.hostname = localhost
database.default.database = your_database_name
database.default.username = your_username
database.default.password = your_password
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

# For PostgreSQL or others, adjust DBDriver and DSN.

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------

encryption.key = 'YourEncryptionKey_32CharsLong'
# Generate a 32‑character key with:
# php spark key:generate

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
session.savePath = WRITEPATH . 'session'
session.matchIP = false
session.timeToUpdate = 300
session.regenerateDestroy = false

# If using database sessions, change driver and set savePath to table name.

#--------------------------------------------------------------------
# EMAIL
#--------------------------------------------------------------------

email.fromEmail = 'your@example.com'
email.fromName = 'Your App Name'
email.SMTPHost = 'smtp.example.com'
email.SMTPUser = 'your_smtp_user'
email.SMTPPass = 'your_smtp_password'
email.SMTPPort = 587
email.SMTPCrypto = 'tls'

#--------------------------------------------------------------------
# LOGGING
#--------------------------------------------------------------------

log.threshold = 4
# 0 = Disabled, 1 = Error, 2 = Debug, 3 = Info, 4 = All

#--------------------------------------------------------------------
# CUSTOM (Optional) - Role‑based dashboard paths
#--------------------------------------------------------------------

# You can define routes as constants to avoid hardcoding in controllers.
# routes.super_admin = '/admin/dashboard'
# routes.manager     = '/manager/dashboard'
# routes.vet         = '/vet/dashboard'
# routes.member      = '/member/dashboard'