{
  "name": "mdgoatco/mdgoatco-farm",
  "description": "MD Goatco Farm Limited — Goat Banking Platform",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.1",
    "codeigniter4/framework": "^4.5",
    "dompdf/dompdf": "^2.0",
    "firebase/php-jwt": "^7.0",
    "kint-php/kint": "^4.0",
    "phpoffice/phpspreadsheet": "^2.1"
  },
  "require-dev": {
    "fakerphp/faker": "^1.23",
    "codeigniter4/devkit": "^1.3.0",
    "roave/security-advisories": "dev-latest"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Config\\": "app/Config/"
    }
  },
  "scripts": {
    "post-update-cmd": [
      "CodeIgniter\\ComposerScripts::postUpdate"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true,
    "audit": {
      "ignore": [
        "PKSA-y2cr-5h3j-g3ys"
      ]
    },
    "allow-plugins": {
      "phpstan/extension-installer": true
    }
  },
  "minimum-stability": "stable"
}
